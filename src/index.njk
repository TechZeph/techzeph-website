---
layout: layout.njk
title: Best AI Tools for UK Trades
---
<section class="hero-bg relative -mx-4 overflow-hidden rounded-3xl border border-slate-200/60 py-16 sm:-mx-6 lg:py-24">
  <div class="absolute -right-28 -top-20 h-96 w-96 rounded-full bg-blue-200/50 blur-3xl"></div>
  <div class="absolute left-0 top-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-rose-200/40 blur-3xl"></div>

  <div class="shell relative z-10 grid items-center gap-12 lg:grid-cols-2">
    <div class="space-y-6">
      <h1 class="text-5xl font-bold leading-[1.05] tracking-tight text-slate-900 lg:text-7xl">
        Power up your
        <span class="block whitespace-nowrap"><span class="bg-gradient-to-r from-blue-700 to-blue-400 bg-clip-text text-transparent">Business</span> with AI.</span>
      </h1>

      <p class="max-w-xl text-lg leading-relaxed text-slate-600 lg:text-xl">
        Compare practical AI tools for UK trades and small businesses. Review pricing, workflows,
        and real-world use cases before you buy.
      </p>

      <div class="flex w-full max-w-xl items-center rounded-xl bg-white p-2 shadow-xl shadow-slate-200/50 ring-1 ring-slate-200">
        <div class="flex h-12 w-12 items-center justify-center text-slate-400">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7"></circle>
            <line x1="16.65" y1="16.65" x2="21" y2="21"></line>
          </svg>
        </div>
        <input class="h-full flex-1 border-none bg-transparent p-2 text-base text-slate-900 placeholder:text-slate-400 focus:outline-none" placeholder="Search invoicing, scheduling, compliance..." type="text">
        <a class="inline-flex h-10 items-center rounded-lg bg-slate-900 px-5 text-sm font-semibold text-white transition hover:bg-blue-700" href="{{ '/tools/' | url }}">Search</a>
      </div>

      <div class="mt-2 flex flex-wrap items-center gap-4 text-sm font-medium text-slate-500">
        <span>Used by UK teams in:</span>
        <div class="flex gap-4 opacity-70 grayscale transition hover:grayscale-0">
          <span class="font-bold">Trades</span>
          <span class="font-bold">Facilities</span>
          <span class="font-bold">SMBs</span>
        </div>
      </div>
    </div>

    <div class="relative flex items-center justify-center lg:h-[500px]">
      <div class="absolute inset-0 opacity-[0.04]" style="background-image:url('https://www.transparenttextures.com/patterns/circuit-board.png');"></div>
      <div class="relative aspect-square w-full max-w-[500px]">
        <div class="absolute left-1/2 top-1/2 z-20 flex h-32 w-32 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-2xl bg-white shadow-2xl ring-4 ring-blue-50">
          <svg aria-hidden="true" viewBox="0 0 24 24" class="h-14 w-14 text-blue-600" fill="currentColor">
            <path d="M5 3h14a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-4l-3 4-3-4H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2zm3 5h8v2H8V8zm0 4h6v2H8v-2z"></path>
          </svg>
        </div>

        <div class="absolute left-10 top-10 rounded-xl border border-slate-100 bg-white p-4 shadow-lg animate-[bounce_3s_ease-in-out_infinite]">
          <p class="text-sm font-semibold text-rose-600">Quotes</p>
        </div>
        <div class="absolute bottom-20 left-0 rounded-xl border border-slate-100 bg-white p-4 shadow-lg animate-[bounce_4s_ease-in-out_infinite]">
          <p class="text-sm font-semibold text-blue-600">Invoices</p>
        </div>
        <div class="absolute right-0 top-1/2 rounded-xl border border-slate-100 bg-white p-4 shadow-lg animate-[bounce_3.5s_ease-in-out_infinite]">
          <p class="text-sm font-semibold text-emerald-600">Compliance</p>
        </div>

        <svg class="pointer-events-none absolute inset-0 h-full w-full text-slate-200" style="z-index:0;">
          <circle class="animate-[spin_20s_linear_infinite]" cx="50%" cy="50%" fill="none" r="30%" stroke="currentColor" stroke-dasharray="8 8" stroke-width="2"></circle>
          <circle class="opacity-50" cx="50%" cy="50%" fill="none" r="45%" stroke="currentColor" stroke-width="1"></circle>
        </svg>
      </div>
    </div>
  </div>
</section>

<section class="relative -mx-4 mt-12 overflow-hidden bg-white py-12 sm:-mx-6">
  <div class="shell mb-8">
    <h2 class="text-2xl font-bold text-slate-900">Modern solutions for modern trades teams</h2>
  </div>
  <div class="group relative h-[400px] w-full overflow-hidden">
    <img
      alt="UK tradesperson using a tablet on site"
      class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
      src="https://images.unsplash.com/photo-1581092160562-40aa08e78837?auto=format&fit=crop&w=2200&q=80"
    >
    <div class="absolute inset-0 flex items-end bg-gradient-to-t from-slate-900/80 to-transparent">
      <div class="shell pb-12">
        <p class="max-w-2xl rounded-lg border border-white/20 bg-white/10 p-4 text-lg font-medium text-white/90 backdrop-blur-sm">
          "The best AI tools reduce admin and make teams faster. We help you find what actually works in UK operations."
        </p>
      </div>
    </div>
  </div>
</section>

<section class="py-20">
  <div class="mb-12 flex flex-col items-end justify-between gap-6 md:flex-row">
    <div class="max-w-2xl">
      <h2 class="text-3xl font-bold text-slate-900 lg:text-4xl">Top AI Categories</h2>
      <p class="mt-3 text-slate-600">Discover specialized tools that streamline quoting, scheduling, customer comms, and daily operations.</p>
    </div>
    <a class="flex items-center gap-1 text-sm font-bold text-blue-700 hover:underline" href="{{ '/best-ai-tools-uk/trades/' | url }}">
      View all categories
      <span aria-hidden="true">></span>
    </a>
  </div>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
    {% for cat in collections.businessCategories %}
      {% if loop.index <= 4 %}
        <a class="group relative flex flex-col justify-between overflow-hidden rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200 transition-all hover:shadow-lg hover:ring-blue-300/70" href="{{ cat.tag | tagHref | url }}">
          {% if loop.index == 1 %}
            <div class="absolute -right-2 -top-2 h-6 w-6 rounded-full bg-blue-50 transition-all group-hover:bg-blue-100"></div>
            <div class="relative z-10 mb-6 flex h-5 w-5 items-center justify-center rounded-sm bg-blue-600 text-white">
              <svg aria-hidden="true" viewBox="0 0 24 24" class="h-2.5 w-2.5" fill="currentColor">
                <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"></path>
              </svg>
            </div>
          {% elif loop.index == 2 %}
            <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-rose-50 transition-all group-hover:bg-rose-100"></div>
            <div class="relative z-10 mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-rose-600 text-white"><span class="text-sm font-bold">S</span></div>
          {% elif loop.index == 3 %}
            <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-emerald-50 transition-all group-hover:bg-emerald-100"></div>
            <div class="relative z-10 mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-emerald-600 text-white"><span class="text-sm font-bold">C</span></div>
          {% else %}
            <div class="absolute -right-4 -top-4 h-24 w-24 rounded-full bg-violet-50 transition-all group-hover:bg-violet-100"></div>
            <div class="relative z-10 mb-6 flex h-12 w-12 items-center justify-center rounded-lg bg-violet-600 text-white"><span class="text-sm font-bold">M</span></div>
          {% endif %}

          <div class="relative z-10">
            <h3 class="text-lg font-bold text-slate-900">{{ cat.label }}</h3>
            <p class="mt-2 text-sm text-slate-500">{{ cat.count }} related guide{% if cat.count != 1 %}s{% endif %} in this category</p>
          </div>
          <div class="mt-4 text-sm font-semibold text-blue-700">
            <span class="transition-transform group-hover:translate-x-1">Explore Tools ></span>
          </div>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

<section class="border-t border-slate-100 py-20">
  <div class="relative overflow-hidden rounded-3xl bg-slate-900 p-8 text-white shadow-2xl lg:p-12">
    <div class="absolute right-0 top-0 h-64 w-64 rounded-full bg-blue-600 opacity-20 blur-[80px]"></div>
    <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-rose-500 opacity-20 blur-[80px]"></div>
    <div class="relative z-10 grid items-center gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-3xl font-bold lg:text-4xl">Unsure which tool is right for your team?</h2>
        <p class="mt-5 text-lg text-slate-300">
          Use our side-by-side comparisons to evaluate pricing, features, and UK fit before choosing a tool.
        </p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a class="inline-flex items-center justify-center rounded-lg bg-white/10 px-8 py-3 text-sm font-bold text-white transition hover:bg-white/20" href="{{ '/tools/' | url }}">Find Tools</a>
          <a class="inline-flex items-center justify-center rounded-lg bg-white/10 px-8 py-3 text-sm font-bold text-white transition hover:bg-white/20" href="{{ '/best-ai-tools-uk/trades/' | url }}">Browse Categories</a>
        </div>
      </div>
      <div class="relative z-10">
        <div class="grid grid-cols-2 gap-4">
          <div class="translate-y-4 rounded-xl border border-white/10 bg-white/10 p-4 backdrop-blur-md">
            <div class="mb-2 h-2 w-12 rounded bg-slate-500"></div>
            <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-full bg-blue-500 text-xs font-bold text-white">A</div>
            <div class="space-y-2">
              <div class="h-2 w-full rounded bg-white/20"></div>
              <div class="h-2 w-3/4 rounded bg-white/20"></div>
              <div class="h-2 w-1/2 rounded bg-white/20"></div>
            </div>
          </div>
          <div class="-translate-y-4 rounded-xl border border-white bg-white p-4 shadow-lg">
            <div class="mb-2 h-2 w-12 rounded bg-slate-200"></div>
            <div class="mb-3 flex h-8 w-8 items-center justify-center rounded-full bg-emerald-500 text-xs font-bold text-white">B</div>
            <div class="space-y-2">
              <div class="h-2 w-full rounded bg-slate-200"></div>
              <div class="h-2 w-3/4 rounded bg-slate-200"></div>
              <div class="h-2 w-full rounded bg-emerald-100"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
