---
pagination:
  data: collections.legacyPostRedirects
  size: 1
  alias: redirect
permalink: "{{ redirect.from }}"
eleventyExcludeFromCollections: true
noindex: true
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta http-equiv="refresh" content="0; url={{ redirect.to | url }}">
  <meta name="robots" content="noindex, nofollow">
  <link rel="canonical" href="{{ site.url }}{{ redirect.to | url }}">
  <title>Redirecting...</title>
</head>
<body>
  <p>Redirecting to <a href="{{ redirect.to | url }}">{{ redirect.title }}</a>.</p>
</body>
</html>
