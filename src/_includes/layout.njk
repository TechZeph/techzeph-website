<!doctype html>
<html lang="en">
<head>
  {% set siteName = site.name or "TechZeph" %}
  {% set pageTitle = seoTitle or title or siteName %}
  {% if pageTitle == siteName %}
    {% set metaTitle = siteName %}
  {% else %}
    {% set metaTitle = pageTitle + " | " + siteName %}
  {% endif %}
  {% set metaDescription = seoDescription or description or site.description %}
  {% set canonicalPath = page.url or "/" %}
  {% if seoCanonical %}
    {% if seoCanonical[0] == "/" %}
      {% set canonicalUrl = site.url + seoCanonical %}
    {% else %}
      {% set canonicalUrl = seoCanonical %}
    {% endif %}
  {% else %}
    {% set canonicalUrl = site.url + canonicalPath %}
  {% endif %}
  {% set ogTypeValue = ogType or "website" %}
  {% set localeValue = site.locale or "en_GB" %}
  {% set rawImage = seoImage or site.defaultImage %}
  {% if rawImage %}
    {% if rawImage[0] == "/" %}
      {% set imageUrl = site.url + rawImage %}
    {% else %}
      {% set imageUrl = rawImage %}
    {% endif %}
  {% endif %}

  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ metaTitle }}</title>
  {% if metaDescription %}
    <meta name="description" content="{{ metaDescription | escape }}">
  {% endif %}
  {% if noindex %}
    <meta name="robots" content="noindex, nofollow">
  {% else %}
    <meta name="robots" content="index, follow">
  {% endif %}
  <link rel="canonical" href="{{ canonicalUrl }}">

  <meta property="og:type" content="{{ ogTypeValue }}">
  <meta property="og:site_name" content="{{ siteName }}">
  <meta property="og:locale" content="{{ localeValue }}">
  <meta property="og:title" content="{{ pageTitle | escape }}">
  {% if metaDescription %}
    <meta property="og:description" content="{{ metaDescription | escape }}">
  {% endif %}
  <meta property="og:url" content="{{ canonicalUrl }}">
  {% if imageUrl %}
    <meta property="og:image" content="{{ imageUrl }}">
  {% endif %}

  {% if imageUrl %}
    <meta name="twitter:card" content="summary_large_image">
  {% else %}
    <meta name="twitter:card" content="summary">
  {% endif %}
  <meta name="twitter:title" content="{{ pageTitle | escape }}">
  {% if metaDescription %}
    <meta name="twitter:description" content="{{ metaDescription | escape }}">
  {% endif %}
  {% if imageUrl %}
    <meta name="twitter:image" content="{{ imageUrl }}">
  {% endif %}
  {% if site.twitterHandle %}
    <meta name="twitter:site" content="{{ site.twitterHandle }}">
  {% endif %}

  {% if structuredData %}
    <script type="application/ld+json">{{ structuredData | json | safe }}</script>
  {% endif %}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ '/assets/css/styles.css' | url }}">
</head>
<body class="text-slate-900">
  <a href="#content" class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:bg-white focus:px-3 focus:py-2 focus:text-sm focus:font-semibold">Skip to content</a>
  {% include "components/header.njk" %}
  <main id="content" class="shell py-10">
    {{ content | safe }}
  </main>
  {% include "components/footer.njk" %}
  <script src="{{ '/assets/js/nav.js' | url }}" defer></script>
  <script src="{{ '/assets/js/consent.js' | url }}" defer></script>
  {% if page.url == "/tools/" %}
    <script src="{{ '/assets/js/tool-finder.js' | url }}" defer></script>
  {% endif %}
</body>
</html>
