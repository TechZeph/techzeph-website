<header id="site-header" class="sticky top-0 z-50 border-b border-slate-200/80 bg-white/85 backdrop-blur-md">
  <div class="shell flex items-center justify-between gap-4 py-3">
    <a class="flex items-center gap-2 text-lg font-bold tracking-tight text-slate-900" href="{{ '/' | url }}">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-slate-100 text-slate-900">
        <svg aria-hidden="true" viewBox="0 0 24 24" class="h-4.5 w-4.5" fill="currentColor">
          <path d="M13 2L4 14h6l-1 8 9-12h-6l1-8z"></path>
        </svg>
      </span>
      <span>TechZeph</span>
    </a>

    <nav class="hidden items-center gap-6 text-sm md:flex" aria-label="Primary">
      {% for item in nav.primary %}
        {% if item.label == "Categories" %}
          <div class="group relative">
            <a
              class="inline-flex items-center gap-1 {{ page.url | activeClass(item) }}"
              href="{{ item.url | url }}"
              aria-haspopup="true"
            >
              {{ item.label }}
              <svg
                aria-hidden="true"
                class="h-4 w-4 text-slate-500 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M20 9l-8 8-8-8 1.414-1.414L12 14.172l6.586-6.586z"></path>
              </svg>
            </a>
            <div class="invisible pointer-events-none absolute left-1/2 top-full w-[min(92vw,42rem)] -translate-x-1/2 pt-2 opacity-0 transition group-hover:visible group-hover:pointer-events-auto group-hover:opacity-100 group-focus-within:visible group-focus-within:pointer-events-auto group-focus-within:opacity-100">
              <div class="max-h-[65vh] overflow-auto rounded-2xl border border-slate-200 bg-white p-4 shadow-xl">
                <div class="mb-3 flex items-center justify-between border-b border-slate-200 pb-2">
                  <p class="text-sm font-semibold text-slate-900">Browse Categories</p>
                  <a class="text-xs font-medium text-slate-600 hover:text-slate-900" href="{{ '/categories/' | url }}">View all</a>
                </div>
                <ul class="grid grid-cols-2 gap-3" role="menu">
                  {% for cat in collections.businessCategories %}
                    {% if loop.index <= 8 %}
                      <li>
                        <a class="block rounded-lg border border-slate-200 p-3 hover:border-slate-300 hover:bg-slate-50" href="{{ cat.tag | tagHref | url }}" role="menuitem">
                          <p class="font-medium text-slate-900">{{ cat.label }}</p>
                          <p class="mt-1 text-xs text-slate-600">{{ cat.count }} guide{% if cat.count != 1 %}s{% endif %}</p>
                        </a>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>
            </div>
          </div>
        {% else %}
          <a class="{{ page.url | activeClass(item) }}" href="{{ item.url | url }}">{{ item.label }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <button
      id="mobile-menu-toggle"
      class="inline-flex items-center justify-center rounded-lg border border-slate-300 p-2 text-slate-700 md:hidden"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <span aria-hidden="true">Menu</span>
    </button>
  </div>
</header>

<div id="mobile-menu" class="fixed inset-0 z-50 hidden md:hidden" aria-hidden="true">
  <div id="mobile-menu-backdrop" class="absolute inset-0 bg-slate-900/55"></div>
  <aside
    class="absolute right-0 top-0 h-full w-full max-w-sm border-l border-slate-200 bg-white p-5 shadow-2xl"
    role="dialog"
    aria-modal="true"
    aria-label="Mobile navigation"
  >
    <div class="mb-5 flex items-center justify-between">
      <p class="text-sm font-semibold uppercase tracking-wide text-slate-500">Menu</p>
      <button id="mobile-menu-close" class="rounded-lg border border-slate-300 px-3 py-1.5 text-sm" type="button" aria-label="Close menu">Close</button>
    </div>

    <a class="mb-4 inline-flex w-full items-center justify-center rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white" href="{{ nav.cta.url | url }}">{{ nav.cta.label }}</a>

    <nav aria-label="Mobile Primary" class="space-y-2">
      {% for item in nav.primary %}
        {% if item.label == "Categories" %}
          <details class="rounded-lg border border-slate-200 p-3">
            <summary class="cursor-pointer list-none text-base font-semibold text-slate-900">Categories</summary>
            <ul class="mt-3 space-y-2 border-t border-slate-200 pt-3">
              <li>
                <a class="block rounded-md px-2 py-1.5 text-sm text-slate-700 hover:bg-slate-100" href="{{ '/categories/' | url }}">View all categories</a>
              </li>
              {% for cat in collections.businessCategories %}
                <li>
                  <a class="block rounded-md px-2 py-1.5 text-sm text-slate-700 hover:bg-slate-100" href="{{ cat.tag | tagHref | url }}">{{ cat.label }}</a>
                </li>
              {% endfor %}
            </ul>
          </details>
        {% else %}
          <a class="block rounded-lg border border-slate-200 px-3 py-2 text-base {{ page.url | activeClass(item) }}" href="{{ item.url | url }}">{{ item.label }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="mt-8 border-t border-slate-200 pt-4">
      <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-slate-500">Trust</p>
      <ul class="space-y-1">
        {% for link in nav.footer %}
          <li>
            <a class="text-sm text-slate-700 hover:text-slate-900" href="{{ link.url | url }}">{{ link.label }}</a>
          </li>
        {% endfor %}
      </ul>
      <p class="mt-3 text-xs text-slate-500">Affiliate disclosure: some links may earn us a commission.</p>
    </div>
  </aside>
</div>
