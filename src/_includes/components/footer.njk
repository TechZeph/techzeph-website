<footer class="mt-20 border-t border-slate-200 bg-white/80">
  <div class="shell flex flex-col gap-4 py-8 text-sm text-slate-600 sm:flex-row sm:items-center sm:justify-between">
    <p>&copy; 2026 TechZeph. Independent reviews for UK trades and small businesses.</p>
    <nav aria-label="Footer" class="flex items-center gap-4">
      {% for link in nav.footer %}
        <a class="hover:text-slate-900 hover:underline" href="{{ link.url | url }}">{{ link.label }}</a>
      {% endfor %}
    </nav>
  </div>
</footer>
