---
layout: layout.njk
---
<article class="mx-auto max-w-3xl">
  {% set effectiveLastUpdated = lastUpdated or lastVerified %}
  {% if not effectiveLastUpdated and page.date %}
    {% set effectiveLastUpdated = page.date %}
  {% endif %}
  {% set effectiveLastVerified = lastVerified or effectiveLastUpdated %}

  <a class="text-sm font-medium text-slate-600 hover:text-slate-900 hover:underline" href="{{ '/best-ai-tools-uk/trades/' | url }}">Back to Categories</a>
  <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">{{ title }}</h1>
  {% if description %}
    <p class="mt-3 text-lg text-slate-700">{{ description }}</p>
  {% endif %}
  <div class="panel mt-8 p-6 sm:p-8">
    <div class="space-y-5 text-slate-800 [&_h2]:scroll-mt-28 [&_h2]:pt-2 [&_h2]:text-2xl [&_h2]:font-semibold [&_ol]:list-decimal [&_ol]:space-y-2 [&_ol]:pl-6 [&_p]:leading-7 [&_table]:w-full [&_table]:border-collapse [&_table]:text-sm [&_tbody_tr]:border-b [&_tbody_tr]:border-slate-200 [&_td]:px-4 [&_td]:py-2 [&_th]:border-b [&_th]:border-slate-300 [&_th]:bg-slate-50 [&_th]:px-4 [&_th]:py-2 [&_th]:text-left [&_th]:text-slate-900 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6">
      {{ content | safe }}
    </div>
  </div>
  {% if effectiveLastUpdated or effectiveLastVerified %}
    <footer class="mt-4 border-t border-slate-200 pt-3 text-xs text-slate-500">
      {% if effectiveLastUpdated %}
        Last updated: {{ effectiveLastUpdated | dateDmy }}
      {% endif %}
      {% if effectiveLastVerified %}
        {% if effectiveLastUpdated %} · {% endif %}
        Last verified: {{ effectiveLastVerified | dateDmy }}
      {% endif %}
    </footer>
  {% endif %}
</article>
