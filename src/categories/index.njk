---
layout: layout.njk
title: Categories
permalink: /categories/
---
<section class="space-y-4">
  <p class="section-kicker">Categories</p>
  <h1 class="page-title">Browse all categories</h1>
  <p class="max-w-3xl text-lg text-slate-700">
    Categories are automatically generated from your published content so discovery stays current as you add posts.
  </p>
</section>

<section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {% for cat in collections.contentTags %}
    <a class="panel p-5 transition hover:-translate-y-0.5 hover:shadow-md" href="{{ cat.tag | tagHref | url }}">
      <h2 class="text-xl font-semibold text-slate-900">{{ cat.label }}</h2>
      <p class="mt-2 text-sm text-slate-600">{{ cat.count }} related guide{% if cat.count != 1 %}s{% endif %}</p>
    </a>
  {% endfor %}
</section>

<section class="panel mt-10 p-6">
  <h2 class="text-2xl font-semibold text-slate-900">How categories are created</h2>
  <p class="mt-2 text-slate-700">Add content with consistent metadata and it appears automatically in both Categories and Tool Finder.</p>
  <a class="mt-4 inline-block text-sm font-semibold text-slate-900 underline underline-offset-4" href="{{ '/tools/' | url }}">Open Tool Finder</a>
</section>
