---
import { canonicalTopicSlug } from "../data/topics";

interface Props {
	tags: readonly string[];
	class?: string;
}

const { tags, class: className = "" } = Astro.props;
---

<div class:list={["flex flex-wrap gap-2", className]}>
	{
		tags.map((tag) => (
			<a
				href={`/topics/${canonicalTopicSlug(tag)}`}
				class="tz-chip px-2.5 py-1 text-xs font-semibold transition hover:-translate-y-0.5 hover:text-[var(--text-primary)]"
			>
				{tag}
			</a>
		))
	}
</div>
