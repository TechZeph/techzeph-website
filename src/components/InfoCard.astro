---
import WindowControls from "./WindowControls.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<article class="tz-window tz-window-interactive transition hover:-translate-y-0.5">
	<div class="tz-window-header tz-project-card-header p-3">
		<div class="flex items-center justify-between gap-4">
			<h2 class="font-display text-xs uppercase leading-none tracking-normal">{title}</h2>
			<WindowControls />
		</div>
	</div>
	<div class="p-4 text-[var(--text-muted)] sm:p-5">
		<slot />
	</div>
</article>
