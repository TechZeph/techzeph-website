---
interface Props { href: string; variant?: "primary" | "secondary" | "inverse"; }
const { href, variant = "primary" } = Astro.props;
const variants = { primary: "tz-button-primary", secondary: "tz-button-secondary", inverse: "tz-button-inverse" };
---
<a href={href} class:list={["tz-button", variants[variant]]}><slot /></a>
