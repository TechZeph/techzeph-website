---
interface Props { tone?: "default" | "muted" | "inverse"; class?: string; [key: string]: unknown; }
const { tone = "default", class: className = "", ...attrs } = Astro.props;
const tones = { default: "", muted: "tz-section-band-muted", inverse: "tz-section-band-inverse" };
---
<section {...attrs} class:list={["tz-section-band", tones[tone], className]}><slot /></section>
