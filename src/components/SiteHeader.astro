---
import ThemeMenu from "./ThemeMenu.astro";

const navItems = [
	{ href: "/", label: "Home" },
	{ href: "/about", label: "About" },
	{ href: "/projects", label: "Projects" },
	{ href: "/ui", label: "UI" },
	{ href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-40 border-b border-[var(--border-subtle)] bg-[color-mix(in_srgb,var(--surface-page)_88%,transparent)] backdrop-blur-xl">
	<nav
		class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6 lg:px-8"
		aria-label="Primary navigation"
	>
		<a href="/" class="group inline-flex items-center gap-2 text-sm font-semibold tracking-normal">
			<span class="grid size-8 place-items-center rounded-md border border-[var(--border-subtle)] bg-[var(--surface-panel)] font-mono text-xs text-[var(--accent-primary)] shadow-[var(--shadow-panel)]">
				TZ
			</span>
			<span>TechZeph</span>
		</a>

		<div class="flex items-center gap-2">
			<div class="flex items-center gap-1 rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-panel)] p-1 text-sm shadow-[var(--shadow-panel)]">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="rounded-full px-3 py-1.5 text-[var(--text-muted)] transition hover:bg-[var(--surface-panel-muted)] hover:text-[var(--text-primary)]"
						>
							{item.label}
						</a>
					))
				}
			</div>
			<ThemeMenu />
		</div>
	</nav>
</header>
