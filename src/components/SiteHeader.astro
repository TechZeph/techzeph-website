---
import SiteMenu from "./SiteMenu.astro";
import ThemeMenu from "./ThemeMenu.astro";
---

<header class="sticky top-0 z-40 border-b border-[var(--border-subtle)] bg-[color-mix(in_srgb,var(--surface-page)_88%,transparent)] backdrop-blur-xl">
	<nav
		class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6 lg:px-8"
		aria-label="Primary navigation"
	>
		<a href="/" class="group inline-flex items-center gap-2 text-sm font-semibold tracking-normal">
			<span class="grid size-8 place-items-center rounded-md border border-[var(--border-subtle)] bg-[var(--surface-panel)] font-mono text-xs text-[var(--accent-primary)] shadow-[var(--shadow-panel)]">
				TZ
			</span>
			<span>TechZeph</span>
		</a>

		<div class="flex items-center gap-2">
			<SiteMenu />
			<ThemeMenu />
		</div>
	</nav>
</header>
