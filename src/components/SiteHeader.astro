---
import ThemeMenu from "./ThemeMenu.astro";

const navItems = [
	{ href: "/", label: "Home" },
	{ href: "/about", label: "About" },
	{ href: "/projects", label: "Projects" },
	{ href: "/ui", label: "UI" },
	{ href: "/contact", label: "Contact" },
];
---

<header class="sticky top-0 z-40 border-b border-[var(--border-subtle)] bg-[color-mix(in_srgb,var(--surface-page)_88%,transparent)] backdrop-blur-xl">
	<nav
		class="mx-auto grid max-w-6xl grid-cols-[1fr_auto] items-center gap-3 px-4 py-3 sm:flex sm:justify-between sm:px-6 lg:px-8"
		aria-label="Primary navigation"
	>
		<a href="/" class="group inline-flex items-center gap-2 text-sm font-semibold tracking-normal">
			<span class="grid size-8 place-items-center rounded-md border border-[var(--border-subtle)] bg-[var(--surface-panel)] font-mono text-xs text-[var(--accent-primary)] shadow-[var(--shadow-panel)]">
				TZ
			</span>
			<span>TechZeph</span>
		</a>

		<div class="col-span-2 row-start-2 min-w-0 overflow-x-auto pb-1 sm:col-span-1 sm:row-auto sm:overflow-visible sm:pb-0">
			<div class="flex w-max min-w-full items-center gap-1 rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-panel)] p-1 text-sm shadow-[var(--shadow-panel)] sm:min-w-0">
				{
					navItems.map((item) => (
						<a
							href={item.href}
							class="shrink-0 rounded-md px-3 py-1.5 text-[var(--text-muted)] transition hover:bg-[var(--surface-panel-muted)] hover:text-[var(--text-primary)]"
						>
							{item.label}
						</a>
					))
				}
			</div>
		</div>
		<ThemeMenu />
	</nav>
</header>
