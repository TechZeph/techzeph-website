---
const path = Astro.url.pathname;
const links = [
  { href: "/ai-ops", label: "AI Ops" },
  { href: "/about", label: "About" },
  { href: "/portfolio", label: "Portfolio" },
  { href: "/contact", label: "Contact" },
];
import SiteMenu from "./SiteMenu.astro";
---
<header class="tz-site-header">
  <nav class="tz-site-nav" aria-label="Primary navigation">
    <a class="tz-wordmark" href="/">TechZeph</a>
    <div class="tz-desktop-nav">
      {links.map((link, index) => (
        <a class="tz-nav-link" aria-current={path === link.href || path.startsWith(`${link.href}/`) ? "page" : undefined} href={link.href}>
          0{index + 1} {link.label}
        </a>
      ))}
    </div>
    <div class="tz-mobile-menu"><SiteMenu /></div>
  </nav>
</header>
