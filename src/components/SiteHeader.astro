---
import { Home } from "@lucide/astro";
import SiteMenu from "./SiteMenu.astro";
import ThemeMenu from "./ThemeMenu.astro";
---

<header class="tz-site-header sticky top-0 z-40 backdrop-blur-xl">
	<nav
		class="mx-auto flex max-w-6xl items-center justify-between gap-3 px-4 py-3 sm:px-6 lg:px-8"
		aria-label="Primary navigation"
	>
		<a
			href="/"
			class="tz-control group inline-flex min-h-10 items-center gap-2 px-3 text-sm font-semibold tracking-normal transition hover:-translate-y-0.5"
		>
			<span class="grid size-6 place-items-center text-[var(--accent-primary)] transition group-hover:text-[var(--accent-primary-hover)]">
				<Home size={15} stroke-width={2.2} aria-hidden="true" />
			</span>
			<span class="text-[var(--text-muted)] transition group-hover:text-[var(--text-primary)]">TechZeph</span>
		</a>

		<div class="flex items-center gap-2">
			<SiteMenu />
			<ThemeMenu />
		</div>
	</nav>
</header>
