---
interface Props {
	kicker: string;
	title: string;
	description?: string;
}

const { kicker, title, description } = Astro.props;
---

<div class="max-w-2xl">
	<p class="font-mono text-sm text-[var(--accent-primary)]">{kicker}</p>
	<h2 class="mt-3 text-3xl font-semibold tracking-normal">{title}</h2>
	{
		description && (
			<p class="mt-4 text-[var(--text-muted)]">
				{description}
			</p>
		)
	}
</div>
