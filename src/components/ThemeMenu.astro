---
import { defaultDarkTheme, defaultLightTheme, themeOptions } from "../data/themes";
---

<div class="relative" data-theme-menu>
	<button
		type="button"
		data-theme-trigger
		class="inline-flex min-h-10 items-center gap-2 rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-panel)] px-3 font-mono text-xs font-semibold text-[var(--text-muted)] shadow-[var(--shadow-panel)] transition hover:-translate-y-0.5 hover:bg-[var(--surface-panel-muted)] hover:text-[var(--text-primary)] hover:shadow-[var(--shadow-interactive)]"
		aria-haspopup="menu"
		aria-expanded="false"
	>
		<span>Theme</span>
		<span aria-hidden="true" class="text-[var(--accent-primary)]">/</span>
		<span data-theme-label>Earth Green</span>
	</button>
	<div
		data-theme-options
		class="absolute right-0 top-12 z-50 hidden w-52 rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-panel)] p-1 shadow-[var(--shadow-interactive)]"
		role="menu"
	>
		{
			themeOptions.map((theme, index) => (
				<button
					type="button"
					data-theme-option={theme.id}
					data-preview-theme={theme.id}
					class:list={[
						"theme-menu-option flex w-full items-center justify-between rounded-md px-3 py-2 text-left font-mono text-xs font-semibold transition",
						index > 0 && "mt-1",
					]}
					role="menuitem"
				>
					<span>{theme.label}</span>
					<span data-theme-check={theme.id} aria-hidden="true" />
				</button>
			))
		}
	</div>
</div>

<script define:vars={{ defaultDarkTheme, defaultLightTheme, themeOptions }}>
	const themeMenu = document.querySelector("[data-theme-menu]");
	const themeTrigger = document.querySelector("[data-theme-trigger]");
	const themeOptionsPanel = document.querySelector("[data-theme-options]");
	const themeLabel = document.querySelector("[data-theme-label]");
	const themeChoiceButtons = document.querySelectorAll("[data-theme-option]");
	const systemPrefersDark = window.matchMedia("(prefers-color-scheme: dark)");
	const themeIds = themeOptions.map((theme) => theme.id);
	const themeLabels = Object.fromEntries(themeOptions.map((theme) => [theme.id, theme.label]));

	function normalizeStoredTheme(theme) {
		if (theme === "light") {
			return defaultLightTheme;
		}

		if (theme === "dark") {
			return defaultDarkTheme;
		}

		return themeIds.includes(theme) ? theme : null;
	}

	function getCurrentTheme() {
		const storedTheme = normalizeStoredTheme(localStorage.getItem("theme"));
		if (storedTheme) {
			return storedTheme;
		}

		return systemPrefersDark.matches ? defaultDarkTheme : defaultLightTheme;
	}

	function setTheme(theme) {
		const nextTheme = normalizeStoredTheme(theme) ?? defaultLightTheme;
		document.documentElement.dataset.theme = nextTheme;
		localStorage.setItem("theme", nextTheme);

		if (themeLabel) {
			themeLabel.textContent = themeLabels[nextTheme] ?? "Theme";
		}

		document.querySelectorAll("[data-theme-check]").forEach((check) => {
			const isSelected = check.getAttribute("data-theme-check") === nextTheme;
			check.textContent = isSelected ? "Selected" : "";
		});
	}

	function closeThemeMenu() {
		themeOptionsPanel?.classList.add("hidden");
		themeTrigger?.setAttribute("aria-expanded", "false");
	}

	function toggleThemeMenu() {
		const isOpen = themeTrigger?.getAttribute("aria-expanded") === "true";
		themeOptionsPanel?.classList.toggle("hidden", isOpen);
		themeTrigger?.setAttribute("aria-expanded", String(!isOpen));
	}

	if (themeTrigger) {
		themeTrigger.addEventListener("click", toggleThemeMenu);
	}

	themeChoiceButtons.forEach((button) => {
		button.addEventListener("click", () => {
			const selectedTheme = button.getAttribute("data-theme-option");
			setTheme(selectedTheme);
			closeThemeMenu();
			themeTrigger?.focus();
		});
	});

	document.addEventListener("click", (event) => {
		if (themeMenu && event.target instanceof Node && !themeMenu.contains(event.target)) {
			closeThemeMenu();
		}
	});

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeThemeMenu();
			themeTrigger?.focus();
		}
	});

	setTheme(getCurrentTheme());
</script>
