---
import { Check, Palette } from "@lucide/astro";
import { defaultDarkTheme, defaultLightTheme, themeOptions } from "../data/themes";

const themeGroups = Object.values(
	themeOptions.reduce(
		(groups, theme) => {
			groups[theme.family] ??= {
				id: theme.family,
				label: theme.familyLabel,
				options: [],
			};

			groups[theme.family].options.push(theme);
			return groups;
		},
		{} as Record<
			string,
			{
				id: string;
				label: string;
				options: typeof themeOptions[number][];
			}
		>,
	),
);

const themeConfigJson = JSON.stringify({
	defaultDarkTheme,
	defaultLightTheme,
	themeOptions,
}).replace(/</g, "\\u003c");
---

<div class="relative" data-theme-menu>
	<script type="application/json" data-theme-config set:html={themeConfigJson}></script>
	<button
		type="button"
		data-theme-trigger
		class="tz-control inline-flex min-h-10 items-center gap-2 px-3 text-xs font-semibold transition hover:-translate-y-0.5"
		aria-haspopup="menu"
		aria-expanded="false"
	>
		<Palette size={15} stroke-width="2" aria-hidden="true" />
		<span>Theme</span>
		<span aria-hidden="true" class="hidden text-[var(--accent-primary)] md:inline">/</span>
		<span data-theme-label class="hidden lg:inline">Earth Green</span>
	</button>
	<div
		data-theme-options
		class="tz-dropdown absolute right-0 top-12 z-50 hidden w-56 max-w-[calc(100vw-2rem)] p-1"
		role="menu"
	>
		{
			themeGroups.map((group, groupIndex) => (
				<div class:list={[groupIndex > 0 && "mt-2"]}>
					<p class="font-display px-3 py-1 text-[0.7rem] uppercase tracking-normal text-[var(--dropdown-text-muted)]">
						{group.label}
					</p>
					<div class="grid grid-cols-2 gap-1">
						{group.options.map((theme) => (
							<button
								type="button"
								data-theme-option={theme.id}
								data-preview-theme={theme.id}
								class="theme-menu-option tz-dropdown-item flex min-h-10 items-center justify-between gap-3 px-3 py-2 text-left text-xs font-semibold transition"
								role="menuitem"
							>
								<span>{theme.label}</span>
								<span class="flex shrink-0 items-center gap-2">
									<span class="theme-preview-swatch" aria-hidden="true">
										<span></span>
										<span></span>
									</span>
									<span
										data-theme-check={theme.id}
										class="grid size-4 place-items-center text-[var(--preview-text)] opacity-0 transition"
										aria-hidden="true"
									>
										<Check size={14} stroke-width="2.5" />
									</span>
								</span>
								<span class="sr-only" data-theme-selected-text={theme.id}></span>
							</button>
						))}
					</div>
				</div>
			))
		}
	</div>
</div>

<script>
	import "../scripts/theme-menu";
</script>
