---
interface Props { kicker: string; title: string; description: string; }
const { kicker, title, description } = Astro.props;
---
<section class="tz-page-intro">
  <p class="tz-kicker">{kicker}</p>
  <div class="tz-page-intro-main">
    <h1>{title}</h1>
    <p class="tz-page-intro-description">{description}</p>
  </div>
</section>
