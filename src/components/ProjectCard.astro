---
import StatusBadge from "./StatusBadge.astro";
import TagList from "./TagList.astro";
import type { Project } from "../data/projects";

interface Props {
	project: Project;
}

const { project } = Astro.props;
---

<article class="tz-window tz-window-interactive flex flex-col transition hover:-translate-y-0.5 md:min-h-72">
	<div class="tz-window-header p-3">
		<div class="flex items-center justify-between gap-3">
			<p class="font-display text-xs uppercase leading-none">{project.type}</p>
			<StatusBadge status={project.status} />
		</div>
	</div>
	<div class="flex flex-1 flex-col p-4 sm:p-5">
		<h3 class="text-xl font-semibold">{project.title}</h3>
		<p class="mt-3 text-sm text-[var(--text-muted)]">{project.summary}</p>
		<TagList tags={project.tags} class="mt-auto pt-6" />
		<a href={`/projects/${project.slug}`} class="mt-5 text-sm font-semibold text-[var(--accent-primary)]">
			Read more
		</a>
	</div>
</article>
