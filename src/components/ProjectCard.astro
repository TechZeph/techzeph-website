---
import StatusBadge from "./StatusBadge.astro";
import type { Project } from "../data/projects";

interface Props {
	project: Project;
}

const { project } = Astro.props;
---

<article class="flex min-h-72 flex-col rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-panel)] p-5 shadow-[var(--shadow-panel)] transition hover:-translate-y-0.5 hover:border-[var(--accent-soft)] hover:shadow-[var(--shadow-interactive)]">
	<div class="flex items-start justify-between gap-3">
		<p class="font-mono text-xs text-[var(--text-muted)]">{project.type}</p>
		<StatusBadge status={project.status} />
	</div>
	<h3 class="mt-5 text-xl font-semibold">{project.title}</h3>
	<p class="mt-3 text-sm text-[var(--text-muted)]">{project.summary}</p>
	<div class="mt-auto flex flex-wrap gap-2 pt-6">
		{
			project.tags.map((tag) => (
				<span class="rounded-md border border-[var(--tag-border)] px-2.5 py-1 font-mono text-xs text-[var(--tag-text)]">
					{tag}
				</span>
			))
		}
	</div>
	<a href={`/projects/${project.slug}`} class="mt-5 text-sm font-semibold text-[var(--accent-primary)]">
		Read case study
	</a>
</article>
