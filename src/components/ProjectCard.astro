---
import { Braces, Code2, FileCode, GitBranch, Palette, Workflow } from "@lucide/astro";
import StatusBadge from "./StatusBadge.astro";
import type { Project } from "../data/projects";

interface Props {
	project: Project;
}

const { project } = Astro.props;

const stackAliases = {
	astro: { label: "Astro", glyph: "A", icon: Code2 },
	"tailwind css": { label: "Tailwind", glyph: "TW", icon: Palette },
	tailwindcss: { label: "Tailwind", glyph: "TW", icon: Palette },
	"github api": { label: "GitHub", glyph: "GH", icon: GitBranch },
	github: { label: "GitHub", glyph: "GH", icon: GitBranch },
	javascript: { label: "JavaScript", glyph: "JS", icon: Braces },
	typescript: { label: "TypeScript", glyph: "TS", icon: Braces },
	css: { label: "CSS", glyph: "CSS", icon: Palette },
	html: { label: "HTML", glyph: "HTML", icon: FileCode },
	documentation: { label: "Docs", glyph: "DOC", icon: FileCode },
	"developer workflow": { label: "Workflow", glyph: "WF", icon: Workflow },
} as const;

const stackSources = [
	...(project.github?.languages?.map((language) => language.name) ?? []),
	project.github?.language,
	...project.tags,
	...(project.skills ?? []),
].filter(Boolean);

const stackGlyphs = Array.from(
	new Map(
		stackSources
			.map((source) => stackAliases[source.toLowerCase() as keyof typeof stackAliases])
			.filter(Boolean)
			.map((stack) => [stack.label, stack]),
	).values(),
).slice(0, 4);
---

<a
	href={`/projects/${project.slug}`}
	data-project-card
	class="tz-window tz-window-interactive group flex flex-col transition hover:-translate-y-0.5 md:min-h-72"
>
	<div class="tz-window-header tz-project-card-header p-3">
		<div class="flex items-center justify-between gap-3">
			<p class="font-display text-xs uppercase leading-none">
				{project.type}
				{project.featured && (
					<span class="ml-2 text-[var(--accent-primary)]">★ Featured</span>
				)}
			</p>
			<StatusBadge status={project.status} />
		</div>
	</div>
	<div class="flex flex-1 flex-col p-4 sm:p-5">
		<h3 class="text-xl font-semibold">{project.title}</h3>
		{
			stackGlyphs.length > 0 && (
				<div class="mt-4 flex flex-wrap gap-2" aria-label="Project technology highlights">
					{stackGlyphs.map((stack) => {
						const Icon = stack.icon;

						return (
							<span
								class="tz-stack-glyph inline-flex items-center gap-1.5 px-2 py-1 text-[0.68rem] font-semibold uppercase"
								title={stack.label}
							>
								<Icon size={13} stroke-width="2.4" aria-hidden="true" />
								<span>{stack.glyph}</span>
							</span>
						);
					})}
				</div>
			)
		}
		<p class="mt-3 text-sm text-[var(--text-muted)]">{project.summary}</p>
		{project.highlights?.[0] && (
			<p class="mt-2 text-xs font-semibold text-[var(--accent-primary)]">{project.highlights[0]}</p>
		)}
		<div class="tz-project-card-reveal-frame grid">
			<p class="tz-project-card-reveal text-xs leading-relaxed">
				{project.currentState}
			</p>
		</div>
		<span class="mt-auto pt-6 text-sm font-semibold text-[var(--accent-primary)]">
			Read more
		</span>
	</div>
</a>

<script>
	const projectCardTouchQuery = window.matchMedia("(hover: none), (pointer: coarse)");

	document.addEventListener("click", (event) => {
		if (!projectCardTouchQuery.matches) {
			return;
		}

		const card = event.target instanceof Element ? event.target.closest("[data-project-card]") : null;

		if (!(card instanceof HTMLAnchorElement)) {
			return;
		}

		if (card.dataset.expanded === "true") {
			return;
		}

		event.preventDefault();

		document.querySelectorAll("[data-project-card][data-expanded='true']").forEach((openCard) => {
			if (openCard !== card) {
				openCard.removeAttribute("data-expanded");
			}
		});

		card.dataset.expanded = "true";
	});
</script>
