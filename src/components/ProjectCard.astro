---
import Panel from "./Panel.astro";
import StatusBadge from "./StatusBadge.astro";
import TagList from "./TagList.astro";
import type { Project } from "../data/projects";

interface Props {
	project: Project;
}

const { project } = Astro.props;
---

<Panel
	as="article"
	class="flex flex-col transition hover:-translate-y-0.5 hover:border-[var(--accent-soft)] hover:shadow-[var(--shadow-interactive)] md:min-h-72"
>
	<div class="flex items-start justify-between gap-3">
		<p class="font-mono text-xs text-[var(--text-muted)]">{project.type}</p>
		<StatusBadge status={project.status} />
	</div>
	<h3 class="mt-5 text-xl font-semibold">{project.title}</h3>
	<p class="mt-3 text-sm text-[var(--text-muted)]">{project.summary}</p>
	<TagList tags={project.tags} class="mt-auto pt-6" />
	<a href={`/projects/${project.slug}`} class="mt-5 text-sm font-semibold text-[var(--accent-primary)]">
		Read case study
	</a>
</Panel>
