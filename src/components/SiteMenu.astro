---
const hubPages = [
  { href: "/ai-ops", label: "AI Ops", description: "Small business workflow audit" },
  { href: "/about", label: "About", description: "Background and current focus" },
  { href: "/portfolio", label: "Portfolio", description: "Public work and current direction" },
  { href: "/contact", label: "Contact", description: "Public contact route" },
];
---
<div data-site-menu>
  <button type="button" data-site-menu-trigger class="tz-menu-trigger" aria-haspopup="menu" aria-expanded="false">Menu / Hubs</button>
  <div data-site-menu-options class="tz-menu-popover hidden" role="menu">
    {hubPages.map((item, index) => (
      <a href={item.href} role="menuitem"><strong>0{index + 1} / {item.label}</strong><span>{item.description}</span></a>
    ))}
  </div>
</div>
<script>
  const menus = document.querySelectorAll("[data-site-menu]");
  menus.forEach((menu) => {
    const trigger = menu.querySelector("[data-site-menu-trigger]");
    const options = menu.querySelector("[data-site-menu-options]");
    const close = () => { options?.classList.add("hidden"); trigger?.setAttribute("aria-expanded", "false"); };
    trigger?.addEventListener("click", () => {
      const open = trigger.getAttribute("aria-expanded") === "true";
      options?.classList.toggle("hidden", open);
      trigger.setAttribute("aria-expanded", String(!open));
    });
    document.addEventListener("click", (event) => { if (event.target instanceof Node && !menu.contains(event.target)) close(); });
    document.addEventListener("keydown", (event) => { if (event.key === "Escape") { close(); if (trigger instanceof HTMLElement) trigger.focus(); } });
  });
</script>
