---
layout: layout.njk
title: Trade Categories
permalink: /best-ai-tools-uk/trades/
---
<section class="space-y-4">
  <p class="section-kicker">Trades</p>
  <h1 class="page-title">Browse trade categories</h1>
  <p class="max-w-3xl text-lg text-slate-700">
    Pick a trade to see tailored AI tool reviews and buying guides.
  </p>
</section>

<section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {% for cat in collections.businessCategories %}
    <a class="panel p-5 transition hover:-translate-y-0.5 hover:shadow-md" href="{{ cat.tag | tagHref | url }}">
      <h2 class="text-xl font-semibold text-slate-900">{{ cat.label }}</h2>
      <p class="mt-2 text-sm text-slate-600">{{ cat.count }} related guide{% if cat.count != 1 %}s{% endif %}</p>
    </a>
  {% endfor %}
</section>
