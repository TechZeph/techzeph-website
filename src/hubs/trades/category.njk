---
layout: layout.njk
pagination:
  data: collections.businessCategories
  size: 1
  alias: tagGroup
permalink: "/best-ai-tools-uk/trades/{{ tagGroup.slug }}/"
title: "Best AI Tools for UK {{ tagGroup.label }} Businesses"
---
<section class="space-y-4">
  <p class="section-kicker">Trade Category</p>
  <h1 class="page-title">Best AI Tools for UK {{ tagGroup.label }} Businesses</h1>
  <p class="max-w-3xl text-lg text-slate-700">
    {{ tagGroup.count }} related guide{% if tagGroup.count != 1 %}s{% endif %} for UK {{ tagGroup.label | lower }} teams.
  </p>
  <a class="inline-block text-sm font-semibold text-slate-900 underline underline-offset-4" href="{{ '/best-ai-tools-uk/trades/' | url }}">Back to all trade categories</a>
</section>

<section class="mt-8 grid gap-4">
  {% for post in tagGroup.posts %}
    <article class="panel p-5">
      <a class="text-xl font-semibold text-slate-900 hover:underline" href="{{ post.url | url }}">{{ post.data.title }}</a>
      {% if post.data.description %}
        <p class="mt-2 text-slate-700">{{ post.data.description }}</p>
      {% endif %}
    </article>
  {% endfor %}
</section>
