---
import InfoCard from "../components/InfoCard.astro";
import PageIntro from "../components/PageIntro.astro";
import SectionHeader from "../components/SectionHeader.astro";
import SectionBand from "../components/SectionBand.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="About | TechZeph"
	description="About TechZeph, the portfolio direction, and the kind of work this site will collect."
>
	<PageIntro
		kicker="/about"
		title="A practical portfolio for technical and creative project work."
		description="I am a self-directed technical builder moving from hospitality and cybersecurity training into AI-assisted software development, web products, automation, and independent digital businesses.
		My current work centres on TechZeph, local AI workflows, agentic coding systems, SEO-driven content sites,
		practical field tools, and experimental automation projects. I enjoy building useful systems from scratch:
		products that combine real-world utility, clean UI, technical depth, and a strong personal design direction.
"
	/>

	<SectionBand>
		<div class="mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.8fr_1fr] lg:px-8">
			<SectionHeader
				kicker="/profile"
				title="Draft content areas"
				description="Public copy should stay modest and easy to replace until the final voice is written."
			/>
			<div class="space-y-4">
				<InfoCard title="Current focus">
					Building the core portfolio, documenting projects clearly, and keeping space for future
					cyber, development, AI, UI, and creative work.
				</InfoCard>
				<InfoCard title="Working style">
					Project-based, practical, iterative, and careful about separating shipped work from
					prototypes, concepts, and learning projects.
				</InfoCard>
			</div>
		</div>
	</SectionBand>
</Layout>
