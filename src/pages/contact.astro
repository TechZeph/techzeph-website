---
import ButtonLink from "../components/ButtonLink.astro";
import PageIntro from "../components/PageIntro.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout
	title="Contact | TechZeph"
	description="Contact page for the TechZeph portfolio."
>
	<PageIntro
		kicker="/contact"
		title="A simple contact page for now."
		description="This page keeps contact options clear while the rest of the portfolio content is still being shaped."
	/>

	<section class="border-y border-[var(--border-subtle)] bg-[var(--surface-page-muted)] py-16">
		<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-xl rounded-lg border border-[var(--border-subtle)] bg-[var(--surface-panel)] p-5 shadow-[var(--shadow-panel)]">
				<h2 class="text-xl font-semibold">Contact details</h2>
				<p class="mt-3 text-[var(--text-muted)]">
					Replace this with the preferred public contact route when ready.
				</p>
				<div class="mt-6">
					<ButtonLink href="mailto:hello@techzeph.co.uk">hello@techzeph.co.uk</ButtonLink>
				</div>
			</div>
		</div>
	</section>
</Layout>
