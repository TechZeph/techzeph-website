---
import ButtonLink from "../components/ButtonLink.astro";
import Layout from "../layouts/Layout.astro";
import PortfolioLinks from "../components/PortfolioLinks.astro";
import SectionBand from "../components/SectionBand.astro";
import SectionHeader from "../components/SectionHeader.astro";
---
<Layout title="TechZeph | Websites, Automations & Practical AI" description="High-trust websites, local AI workflows, and useful automations for small teams who want their online presence to work harder.">
  <section class="tz-home-hero">
    <p class="tz-kicker">Independent studio</p>
    <div class="tz-home-hero-main">
      <h1>Websites with <em>signal.</em> Systems with momentum.</h1>
      <p class="tz-home-lede">TechZeph builds sharp service pages, practical automations, and local-first AI workflows for people who want their online presence to feel alive, credible, and useful.</p>
      <div class="tz-home-actions"><ButtonLink href="/contact">Start a project</ButtonLink><ButtonLink href="/portfolio" variant="secondary">View the portfolio</ButtonLink></div>
    </div>
  </section>
  <SectionBand tone="muted">
    <div class="tz-container">
      <SectionHeader kicker="Portfolio" title="Websites, code and professional experience." description="View my GitHub projects, LinkedIn profile and the website I’m building for Duke’s Po-Boys." />
      <PortfolioLinks />
    </div>
  </SectionBand>

  <SectionBand tone="inverse">
    <div class="tz-container grid gap-8 lg:grid-cols-[1fr_auto] lg:items-end">
      <div><p class="tz-kicker !text-[var(--accent-soft)]">/contact</p><h2 class="tz-serif mt-4 max-w-4xl text-5xl leading-[.9] tracking-[-.05em] sm:text-7xl">Bring the messy workflow. I’ll turn it into a sharper system.</h2><p class="mt-6 max-w-2xl text-[var(--text-inverse-muted)]">Email me about website design, custom automations, local AI setup, or practical workflow improvements for your business.</p></div>
      <ButtonLink href="mailto:hello@techzeph.co.uk" variant="inverse">hello@techzeph.co.uk</ButtonLink>
    </div>
  </SectionBand>
</Layout>
