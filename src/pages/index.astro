---
import ButtonLink from "../components/ButtonLink.astro";
import Layout from "../layouts/Layout.astro";
import Panel from "../components/Panel.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SectionBand from "../components/SectionBand.astro";
import SectionHeader from "../components/SectionHeader.astro";
import StatusBadge from "../components/StatusBadge.astro";
import { projects } from "../data/projects";

const focusItems = [
	"Building the core portfolio structure.",
	"Ensuring the website can stay up to date, hands-free.",
	"Making room for cyber, dev, AI, and broader project work, later.",
];
---

<Layout
	title="TechZeph | Project Portfolio"
	description="A calm technical portfolio for projects, experiments, automations, and interface work."
>
	<section class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:gap-12 sm:px-6 sm:py-20 lg:grid-cols-[1.1fr_0.9fr] lg:px-8 lg:py-24">
		<div class="flex flex-col justify-center">
			<p class="font-display mb-5 text-sm uppercase text-[var(--accent-primary)]">/portfolio /projects /lab</p>
			<h1 class="max-w-4xl text-3xl font-semibold leading-tight tracking-normal text-[var(--text-primary)] sm:text-5xl lg:text-6xl">
				A calm technical portfolio for projects, experiments, custom automations, and interface work.
			</h1>
			<p class="mt-5 max-w-2xl text-base text-[var(--text-muted)] sm:mt-6 sm:text-lg">
				TechZeph is a personal portfolio: practical, fast, and flexible.
				Programmatic approaches to data driven components, so that information is pulled automatically, reliably.
				<br><br>This website always remains up to date, and will always showcase my latest work. No manual editing.
				No having to constantly update your site with the latest pictures, videos and work. Contact me for paid custom automations.
			</p>
			<div class="mt-8 flex flex-col gap-3 sm:flex-row">
				<ButtonLink href="/projects" variant="secondary">View current work</ButtonLink>
				<ButtonLink href="/contact" variant="secondary">Contact</ButtonLink>
			</div>
		</div>

		<Panel as="aside" aria-label="Current site status">
			<div class="tz-divider-b flex items-center justify-between gap-4 pb-4">
				<p class="font-display text-sm uppercase text-[var(--accent-primary)]">status</p>
				<StatusBadge status="v0.1" />
			</div>
			<div class="space-y-6 pt-5">
				<div>
					<p class="text-sm font-semibold text-[var(--text-primary)]">Current build</p>
					<p class="mt-2 text-sm text-[var(--text-muted)]">
						Lightweight UI, minimalistic thematic choices, and an up to date showcase; Directly pulled from GitHub live data.
					</p>
				</div>
				<div>
					<p class="text-sm font-semibold text-[var(--text-primary)]">Next Tasks</p>
					<p class="font-display mt-2 text-sm text-[var(--text-muted)]">
						Programmatic and dynamically updating components across the site.
						Design mood pulling directly from themes.
						Programmatic Versioning, for this component block.
					</p>
				</div>
				<div>
					<p class="text-sm font-semibold text-[var(--text-primary)]">Design mood</p>
					<p class="mt-2 text-sm text-[var(--text-muted)]">
						Earthy green, dark mode or light mode. Spacious, technical, and deliberately restrained.
						Retro elements with brutalist accents.
					</p>
				</div>
			</div>
		</Panel>
	</section>

	<SectionBand>
		<div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
			<SectionHeader
				kicker="/work"
				title="Current project map"
				description="Projects are pulled from GitHub repo metadata at build time, then labelled by status so the index stays honest as the work changes."
			/>

			<div class="mt-8 grid gap-4 md:grid-cols-3">
				{projects.map((project) => <ProjectCard project={project} />)}
			</div>
		</div>
	</SectionBand>

	<section id="focus" class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 sm:py-16 lg:grid-cols-[0.8fr_1fr] lg:gap-10 lg:px-8">
		<div>
			<p class="font-display text-sm uppercase text-[var(--accent-primary)]">/focus</p>
			<h2 class="mt-3 text-2xl font-semibold tracking-normal sm:text-3xl">Built for speed, staying up to date with data.</h2>
		</div>
		<div class="space-y-4">
			{
				focusItems.map((item, index) => (
					<Panel class="flex gap-4" padding="sm">
						<span class="font-display text-sm text-[var(--accent-primary)]">
							{String(index + 1).padStart(2, "0")}
						</span>
						<p class="text-[var(--text-muted)]">{item}</p>
					</Panel>
				))
			}
		</div>
	</section>

	<SectionBand id="contact" tone="inverse">
		<div class="mx-auto flex max-w-6xl flex-col gap-6 px-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between lg:px-8">
			<div class="max-w-2xl">
				<p class="font-display text-sm uppercase text-[var(--accent-soft)]">/contact</p>
				<h2 class="mt-3 text-2xl font-semibold tracking-normal sm:text-3xl">A simple starting point.</h2>
				<p class="mt-4 text-[var(--text-inverse-muted)]">
					You may contact me at the following email for Design work, Automations, Local AI setup and Custom Workflows for your business' needs.
				</p>
			</div>
			<a
				href="mailto:hello@techzeph.co.uk"
				class="tz-hard-control inline-flex items-center justify-center bg-[var(--button-inverse-bg)] px-5 py-3 text-sm font-semibold text-[var(--button-inverse-text)] transition hover:-translate-y-0.5 hover:bg-[var(--button-inverse-bg-hover)] sm:w-auto"
			>
				hello@techzeph.co.uk
			</a>
		</div>
	</SectionBand>
</Layout>
