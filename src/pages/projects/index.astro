---
import PageIntro from "../../components/PageIntro.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import SectionBand from "../../components/SectionBand.astro";
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";
---

<Layout
	title="Projects | TechZeph"
	description="Project case studies, prototypes, concepts, and planned work for the TechZeph portfolio."
>
	<PageIntro
		kicker="/projects"
		title="Projects, prototypes, and case studies."
		description="A structured index for finished work, planned systems, learning projects, and experiments. Each item is labelled by status to avoid overclaiming."
	/>

	<SectionBand>
		<div class="mx-auto grid max-w-6xl gap-4 px-4 sm:px-6 md:grid-cols-3 lg:px-8">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</SectionBand>
</Layout>
