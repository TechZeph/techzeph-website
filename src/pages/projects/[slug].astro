---
import ButtonLink from "../../components/ButtonLink.astro";
import InfoCard from "../../components/InfoCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import SectionBand from "../../components/SectionBand.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import TagList from "../../components/TagList.astro";
import WindowControls from "../../components/WindowControls.astro";
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
const languages = project.github?.languages ?? [];
const skills = project.skills ?? [];
const buildContext = project.complexity?.notes;
const nextStepPreview = project.nextSteps[0] ?? "Keep iterating on the project as the repository evolves.";
const commitHistoryUrl = project.repositoryUrl && project.github?.defaultBranch
	? `${project.repositoryUrl}/commits/${project.github.defaultBranch}`
	: project.repositoryUrl;
const repositorySignals = [
	project.github?.sizeKb ? `${project.github.sizeKb.toLocaleString("en-GB")} KB repository size` : "",
	project.github ? `${project.github.stars} star${project.github.stars === 1 ? "" : "s"}` : "",
	project.github ? `${project.github.forks} fork${project.github.forks === 1 ? "" : "s"}` : "",
	project.github?.pushedAt ? `Last pushed ${new Date(project.github.pushedAt).toISOString().slice(0, 10)}` : "",
].filter(Boolean);

const caseStudy = project.caseStudy;
const highlights = project.highlights ?? [];
const learned = project.learned ?? [];
const license = project.github?.license;
const latestRelease = project.github?.latestRelease;
const socialImage = project.ogImage ?? project.github?.socialImage;
const timeline = [project.started, project.shipped].filter(Boolean).join(" → ");
const relatedProjects = (project.related ?? [])
	.map((slug) => projects.find((candidate) => candidate.slug === slug))
	.filter((candidate): candidate is typeof project => Boolean(candidate));
const releaseSignals = [
	license ? `License: ${license.spdxId}` : "",
	latestRelease ? `Latest release: ${latestRelease.name}` : "",
	typeof project.github?.openIssues === "number" ? `${project.github.openIssues} open issues / PRs` : "",
	timeline ? `Timeline: ${timeline}` : "",
].filter(Boolean);
---

<Layout
	title={`${project.title} | TechZeph`}
	description={project.summary}
	image={socialImage}
>
	<PageIntro
		kicker={`/projects/${project.slug}`}
		title={project.title}
		description={project.summary}
	/>

	<SectionBand>
		<div class="mx-auto grid max-w-6xl items-start gap-8 px-4 sm:px-6 lg:grid-cols-[0.7fr_1fr] lg:px-8">
			<aside class="tz-window tz-window-interactive transition hover:-translate-y-0.5">
				<div class="tz-window-header tz-project-card-header p-3">
					<div class="flex items-center justify-between gap-4">
						<h2 class="font-display text-xs uppercase leading-none tracking-normal">Project overview</h2>
						<WindowControls />
					</div>
				</div>
				<div class="p-5">
					<div class="flex items-start justify-between gap-4">
						<p class="font-display text-sm uppercase text-[var(--text-muted)]">{project.type}</p>
						<StatusBadge status={project.status} />
					</div>
					<TagList tags={project.tags} class="mt-6" />
					<div class="mt-8 flex flex-col gap-3">
						<ButtonLink href="/projects" variant="secondary">Back to projects</ButtonLink>
						{project.repositoryUrl && <ButtonLink href={project.repositoryUrl} variant="secondary">GitHub repo</ButtonLink>}
						{project.homepageUrl && <ButtonLink href={project.homepageUrl} variant="secondary">Live site</ButtonLink>}
						{project.demoUrl && <ButtonLink href={project.demoUrl} variant="secondary">Live demo</ButtonLink>}
						{latestRelease && <ButtonLink href={latestRelease.url} variant="secondary">Latest release</ButtonLink>}
					</div>
				</div>
			</aside>

			<div class="space-y-4">
				<div class="flex flex-col gap-4 md:flex-row md:items-start">
					<div class="md:w-fit md:max-w-xs">
						<InfoCard title="Build role">
							{project.role}
						</InfoCard>
					</div>
					<div class="md:min-w-0 md:flex-1">
						<InfoCard title="Next">
							{nextStepPreview}
						</InfoCard>
					</div>
				</div>
				{
					skills.length > 0 && (
						<InfoCard title="Skills and tooling">
							<TagList tags={skills} />
						</InfoCard>
					)
				}
				{
					highlights.length > 0 && (
						<InfoCard title="Highlights">
							<ul class="list-disc space-y-1 pl-5">
								{highlights.map((item) => <li>{item}</li>)}
							</ul>
						</InfoCard>
					)
				}
				{
					caseStudy && (
						<InfoCard title="Case study">
							<div class="space-y-4">
								{caseStudy.problem && (
									<div>
										<h3 class="font-display text-xs uppercase text-[var(--text-muted)]">Problem</h3>
										<p class="mt-1">{caseStudy.problem}</p>
									</div>
								)}
								{caseStudy.approach && (
									<div>
										<h3 class="font-display text-xs uppercase text-[var(--text-muted)]">Approach</h3>
										<p class="mt-1">{caseStudy.approach}</p>
									</div>
								)}
								{caseStudy.outcome && (
									<div>
										<h3 class="font-display text-xs uppercase text-[var(--text-muted)]">Outcome</h3>
										<p class="mt-1">{caseStudy.outcome}</p>
									</div>
								)}
							</div>
						</InfoCard>
					)
				}
				{
					languages.length > 0 && (
						<InfoCard title="Detected languages">
							<ul class="space-y-2">
								{languages.map((language) => (
									<li class="tz-divider-b flex items-center justify-between gap-4 pb-2 last:border-b-0 last:pb-0">
										<span>{language.name}</span>
										<span class="font-display text-sm">{language.percentage}%</span>
									</li>
								))}
							</ul>
						</InfoCard>
					)
				}
				{
					buildContext && (
						<InfoCard title="Build context">
							<p>{buildContext}</p>
						</InfoCard>
					)
				}
				{
					repositorySignals.length > 0 && (
						<InfoCard title="Repository signals">
							<ul class="list-disc space-y-1 pl-5">
								{repositorySignals.map((signal) => <li>{signal}</li>)}
							</ul>
						</InfoCard>
					)
				}
				{
					releaseSignals.length > 0 && (
						<InfoCard title="Release & license">
							<ul class="list-disc space-y-1 pl-5">
								{releaseSignals.map((signal) => <li>{signal}</li>)}
							</ul>
						</InfoCard>
					)
				}
				<InfoCard title="What has been done">
					<div class="space-y-5">
						<ul class="list-disc space-y-1 pl-5">
							{project.done.map((item) => <li>{item}</li>)}
						</ul>
						{
							commitHistoryUrl && (
								<div class="tz-divider-t pt-4">
									<a
										href={commitHistoryUrl}
										class="font-display inline-flex text-xs uppercase text-[var(--accent-primary)] transition hover:text-[var(--accent-primary-hover)]"
									>
										See full history
									</a>
								</div>
							)
						}
					</div>
				</InfoCard>
				<InfoCard title="What I want to do next">
					<ul class="list-disc space-y-1 pl-5">
						{project.nextSteps.map((item) => <li>{item}</li>)}
					</ul>
				</InfoCard>
				{
					learned.length > 0 && (
						<InfoCard title="What I learned">
							<ul class="list-disc space-y-1 pl-5">
								{learned.map((item) => <li>{item}</li>)}
							</ul>
						</InfoCard>
					)
				}
				{
					relatedProjects.length > 0 && (
						<InfoCard title="Related projects">
							<ul class="space-y-1">
								{relatedProjects.map((related) => (
									<li>
										<a
											href={`/projects/${related.slug}`}
											class="font-semibold text-[var(--accent-primary)] transition hover:text-[var(--accent-primary-hover)]"
										>
											{related.title}
										</a>
									</li>
								))}
							</ul>
						</InfoCard>
					)
				}
			</div>
		</div>
	</SectionBand>
</Layout>
