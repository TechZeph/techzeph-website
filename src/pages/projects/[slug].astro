---
import ButtonLink from "../../components/ButtonLink.astro";
import InfoCard from "../../components/InfoCard.astro";
import PageIntro from "../../components/PageIntro.astro";
import Panel from "../../components/Panel.astro";
import SectionBand from "../../components/SectionBand.astro";
import StatusBadge from "../../components/StatusBadge.astro";
import TagList from "../../components/TagList.astro";
import Layout from "../../layouts/Layout.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

const { project } = Astro.props;
---

<Layout
	title={`${project.title} | TechZeph`}
	description={project.summary}
>
	<PageIntro
		kicker={`/projects/${project.slug}`}
		title={project.title}
		description={project.summary}
	/>

	<SectionBand>
		<div class="mx-auto grid max-w-6xl gap-8 px-4 sm:px-6 lg:grid-cols-[0.7fr_1fr] lg:px-8">
			<Panel as="aside">
				<div class="flex items-start justify-between gap-4">
					<p class="font-mono text-sm text-[var(--text-muted)]">{project.type}</p>
					<StatusBadge status={project.status} />
				</div>
				<TagList tags={project.tags} class="mt-6" />
				<div class="mt-8">
					<ButtonLink href="/projects" variant="secondary">Back to projects</ButtonLink>
				</div>
			</Panel>

			<div class="space-y-4">
				{
					[
						["My role", project.role],
						["Current state", project.currentState],
						["What I learned", project.learned],
						["What I would improve next", project.next],
					].map(([title, body]) => (
						<InfoCard title={title}>{body}</InfoCard>
					))
				}
			</div>
		</div>
	</SectionBand>
</Layout>
