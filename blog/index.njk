---
layout: layout.njk
title: Blog
permalink: /blog/
---
<section class="space-y-4">
  <p class="section-kicker">Blog</p>
  <h1 class="page-title">Guides, comparisons, and practical AI workflows</h1>
  <p class="max-w-3xl text-lg text-slate-700">Editorial content focused on UK trades and small business operators.</p>
</section>

<ul class="mt-8 space-y-4">
  {% for post in collections.blog | reverse %}
    <li class="panel p-5">
      <a class="text-xl font-semibold text-slate-900 hover:underline" href="{{ post.url }}">{{ post.data.title }}</a>
      {% if post.data.description %}
        <p class="mt-2 text-slate-700">{{ post.data.description }}</p>
      {% endif %}
    </li>
  {% endfor %}
</ul>
