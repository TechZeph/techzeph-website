---
layout: layout.njk
---
<article class="mx-auto max-w-3xl">
  <a class="text-sm font-medium text-slate-600 hover:text-slate-900 hover:underline" href="/blog/">Back to Blog</a>
  <h1 class="mt-3 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">{{ title }}</h1>
  {% if description %}
    <p class="mt-3 text-lg text-slate-700">{{ description }}</p>
  {% endif %}
  <div class="panel mt-8 p-6 sm:p-8">
    <div class="space-y-5 text-slate-800 [&_h2]:scroll-mt-28 [&_h2]:pt-2 [&_h2]:text-2xl [&_h2]:font-semibold [&_ol]:list-decimal [&_ol]:space-y-2 [&_ol]:pl-6 [&_p]:leading-7 [&_ul]:list-disc [&_ul]:space-y-2 [&_ul]:pl-6">
      {{ content | safe }}
    </div>
  </div>
</article>
