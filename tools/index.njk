---
layout: layout.njk
title: Tool Finder
permalink: /tools/
---
<section class="hero-bg relative -mx-4 overflow-hidden rounded-3xl border border-slate-200/60 px-6 py-12 sm:-mx-6 sm:px-10">
  <div class="absolute -right-16 -top-16 h-64 w-64 rounded-full bg-blue-200/40 blur-3xl"></div>
  <div class="absolute -left-20 bottom-0 h-56 w-56 rounded-full bg-rose-200/40 blur-3xl"></div>
  <div class="relative z-10">
    <p class="section-kicker">Tool Finder</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight text-slate-950 sm:text-5xl">Find the right AI tools faster</h1>
    <p class="mt-3 max-w-3xl text-lg text-slate-700">What type of trade or business do you want to find tools for?</p>

    <label for="tool-finder-search" class="mt-6 block text-sm font-semibold text-slate-800">Search trade or business</label>
    <div class="mt-2 flex w-full items-center gap-3 rounded-xl border border-slate-300 bg-white p-2 shadow-sm focus-within:border-slate-900 sm:max-w-3xl">
      <svg aria-hidden="true" viewBox="0 0 24 24" class="ml-2 h-5 w-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="16.65" y1="16.65" x2="21" y2="21"></line>
      </svg>
      <input
        id="tool-finder-search"
        type="search"
        placeholder="e.g. electrician, plumber, builder, agency"
        class="w-full border-0 bg-transparent px-1 py-2 text-base text-slate-900 placeholder:text-slate-500 focus:outline-none"
        autocomplete="off"
      >
    </div>

    <div class="mt-4 flex flex-wrap gap-2">
      <button type="button" class="tool-chip chip" data-query="electrician">Electrician</button>
      <button type="button" class="tool-chip chip" data-query="plumber">Plumber</button>
      <button type="button" class="tool-chip chip" data-query="builder">Builder</button>
      <button type="button" class="tool-chip chip" data-query="small business">Small Business</button>
      <button type="button" class="tool-chip chip" data-query="marketing">Marketing</button>
    </div>
    <p id="tool-finder-count" class="mt-3 text-sm text-slate-600">Showing all categories.</p>
  </div>
</section>

<section id="tool-finder-grid" class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {% for cat in nav.categories %}
    <a
      class="tool-card panel p-5 transition hover:-translate-y-0.5 hover:shadow-md"
      href="{{ cat.url }}"
      data-search="{{ cat.label | lower }} {{ cat.description | lower }} electricians plumbers builders trades small business uk"
    >
      <h2 class="text-xl font-semibold text-slate-900">{{ cat.label }}</h2>
      <p class="mt-2 text-sm text-slate-600">{{ cat.description }}</p>
    </a>
  {% endfor %}
</section>

<p id="tool-finder-empty" class="panel mt-6 hidden p-4 text-sm text-slate-700">
  No category matches that search yet. Try a broader term like <span class="font-semibold">trades</span>, <span class="font-semibold">marketing</span>, or <span class="font-semibold">admin</span>.
</p>
